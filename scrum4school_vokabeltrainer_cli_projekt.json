                                                  "content":  "import json\nimport random\n\n\ndef load_vocab(path=\"latein_vokabeln.json\"):\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        data = json.load(f)\n    return data[\"vokabeln\"]\n\n\ndef main():\n    vocab = load_vocab()\n    fragen = min(8, len(vocab))\n    score = 0\n\n    print(\"Latein Vokabeltest v2\")\n    for eintrag in random.sample(vocab, fragen):\n        latein = eintrag[\"latein\"]\n        loesungen = [w.lower() for w in eintrag[\"deutsch\"]]\n        antwort = input(f\"{latein} = \").strip().lower()\n\n        if antwort in loesungen:\n            print(\"richtig\")\n            score += 1\n        else:\n            print(f\"falsch, loesung: {\u0027, \u0027.join(eintrag[\u0027deutsch\u0027])}\")\n\n    print(f\"Ergebnis: {score}/{fragen}\")\n\n\nif __name__ == \"__main__\":\n    main()",
