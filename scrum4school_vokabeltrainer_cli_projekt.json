                                                  "content":  "import random\n\nVOCAB = [\n    (\"amicus\", \"freund\"),\n    (\"puella\", \"maedchen\"),\n    (\"puer\", \"junge\"),\n    (\"domus\", \"haus\"),\n    (\"aqua\", \"wasser\")\n]\n\n\ndef main():\n    print(\"Latein Vokabeltest v1\")\n    fragen = min(5, len(VOCAB))\n    score = 0\n\n    for latein, deutsch in random.sample(VOCAB, fragen):\n        antwort = input(f\"{latein} = \").strip().lower()\n        if antwort == deutsch:\n            print(\"richtig\")\n            score += 1\n        else:\n            print(f\"falsch, loesung: {deutsch}\")\n\n    print(f\"Ergebnis: {score}/{fragen}\")\n\n\nif __name__ == \"__main__\":\n    main()",
