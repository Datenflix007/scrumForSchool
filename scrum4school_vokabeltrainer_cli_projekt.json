                                                  "path":  "vokabeltest.py",
                                                  "size":  1718,
                                                  "lastModified":  1770028200000,
                                                  "content":  "import argparse\nimport json\nimport random\nimport re\n\n\ndef normalize(text):\n    text = text.lower().strip()\n    text = re.sub(r\"[^a-z0-9 ]+\", \"\", text)\n    return re.sub(r\"\\s+\", \" \", text)\n\n\ndef load_vocab(path):\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        data = json.load(f)\n    return data.get(\"vokabeln\", [])\n\n\ndef ask_round(items, titel):\n    print(f\"\\n{titel}\")\n    score = 0\n    wrong = []\n\n    for i, eintrag in enumerate(items, start=1):\n        latein = eintrag[\"latein\"]\n        loesungen = {normalize(w) for w in eintrag[\"deutsch\"]}\n        antwort = normalize(input(f\"{i}. {latein} = \"))\n        if antwort in loesungen:\n            print(\"richtig\")\n            score += 1\n        else:\n            print(f\"falsch, loesung: {\u0027, \u0027.join(eintrag[\u0027deutsch\u0027])}\")\n            wrong.append(eintrag)\n\n    return score, wrong\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Einfacher Latein Vokabeltrainer\")\n    parser.add_argument(\"--datei\", default=\"latein_vokabeln.json\")\n    parser.add_argument(\"--anzahl\", type=int, default=10)\n    parser.add_argument(\"--wiederholen\", action=\"store_true\", help=\"Falsche Antworten einmal wiederholen\")\n    args = parser.parse_args()\n\n    vocab = load_vocab(args.datei)\n    if not vocab:\n        print(\"Keine Vokabeln gefunden.\")\n        return\n\n    auswahl = random.sample(vocab, min(args.anzahl, len(vocab)))\n    score, wrong = ask_round(auswahl, \"Runde 1\")\n\n    if args.wiederholen and wrong:\n        extra_score, wrong2 = ask_round(wrong, \"Runde 2 (nur falsche)\")\n        score += extra_score\n        wrong = wrong2\n\n    print(f\"\\nGesamtergebnis: {score} richtig\")\n    print(f\"Offen falsch: {len(wrong)}\")\n\n\nif __name__ == \"__main__\":\n    main()",
